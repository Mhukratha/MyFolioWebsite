---
import Layout from "../layouts/Layout.astro"

---

<Layout title="About Me">
  <main>
    <section id="about" class="about-section">
				<div class="container">
				<h2 class="bg-title">About<span> Me</span></h2>
					<div class="about-grid">
						<div class="about-info">
							<h3>I'm Yossawin Kasiphongphaisan</h3>
						</div>
						<div class="about-image">
							<img src="/my-MyFolioWebpage/img/Yossawin.png" alt="Yossawin">
						</div>
					</div>
          <div class="about-info">
							<p>I'm a Junior Software Developer with a strong interest in writing clear, maintainable code and building systems that work reliably in real use cases. 
							I enjoy working with structured logic, understanding how systems behave, and improving performance through careful debugging and iteration. 
							</p>
              <p> My experience comes from project-based development using C# and Unity, where I’ve implemented core systems, handled problem-solving tasks, and collaborated closely with team members. I’m comfortable learning new tools, adapting to different requirements, and continuously improving my technical skills.
							</p>
              <p> I’m currently seeking an entry-level position where I can grow as a developer, contribute to a development team, and work on meaningful software projects.
							</p>
						</div>
          <!-------------------- Skill Tab ----------------------->
					<div class="skills-tabs">
            <div class="tab-item active" data-category="technical">
              <strong>Technical Skills</strong>
            </div>
            <div class="tab-item inactive" data-category="professional">
              <strong>Professional Strengths</strong>
            </div>
            <div class="tab-item inactive" data-category="additional">
              <strong>Additional Skills</strong>
            </div>
            </div>
            <!-------------------- Skill grid ----------------------->
						<div class="skills-content">
							<div class="skills-grid" id="skills-grid-container">
							</div>
						</div>
            <!-------------------- info  ----------------------->
            <div class="skill-detail-box">
              <p id="skill-detail-text">Experience</p>
            </div>
					</div>
				</div>
			</section>
  </main>
</Layout>

<style is:global>
  .about-section {
    min-height: 100vh;
    padding: 100px 10%;
  }
	.about-grid{
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    align-items: center;
    gap: 50px;
    margin: 5% 0;
    justify-content: center;

    max-width: 1000px;       
    margin: 5% auto;        
    gap: 50px;              
    width: 100%;
  }
  .about-info {
    flex: 2;
    text-align: left;
    margin: 10% auto;
  }
	.about-info h3 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-family: cursive;
    margin: 0;
  }
  .about-info p {
    font-size: clamp(0.5rem, 5vw, 1.2rem);
    font-family: cursive; color: #fdcdff;
    line-height: 1.5;
    margin: 10 auto;
  }
  .about-image {
    flex: 1;
    display: flex;
    justify-content: center;
    img {
    width: 100%;
    max-width: 300px;
    height: auto;
    filter: drop-shadow(0 0 30px rgba(255, 255, 255, 0.1));}
  }
  /* ---------------------------tab--------------------------------- */
  .skills-tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    max-width: 1000px;
    margin: 10px auto;
    width: 100%;
    transition: all 0.5s ease; 
    min-height: 70px;
  }
  .tab-item {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000000;
    border-radius: 15px;
    cursor: pointer;
    flex: 1;
    padding: 15px 10px;
    transition: all 0.5s ease;
    opacity: 0.6;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }
  .tab-item strong {
    color: #fff;
    margin: 0;
    line-height: 1.2;
    font-size: clamp(0.5rem, 1.5vw, 1rem);
    text-transform: uppercase;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }
  .tab-item.active {
    background: #f5f5f5; 
    opacity: 1;
    flex: 2; 
    transform: translateY(-5px);
  }
  .tab-item.active strong {
    color: #000;
  }
  /* ---------------------------tab--------------------------------- */
  /* ---------------------------content--------------------------------- */
  .skills-content {
    min-height: 450px;
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 15px;
    padding: clamp(15px, 3vw, 30px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 1000px;
    margin: 0 auto 10% auto;
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 20px;
    
  }
  .skill-card {
    background: #ececec;
    height: 110px;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #000000;
    font-size: 0.8rem;
    font-weight: bold;
    text-align: center;
    padding: 10px;
    animation: fadeIn 0.3s ease-in-out;
    i{
    font-size: 2.5rem;
    margin-bottom: 10px;
    transition: transform 0.3s ease;
  }
  }
  .skill-info {
  font-size: 0.75rem;
  color: #666;
  margin-top: 0;
  max-height: 0;
  opacity: 0;
  transition: all 0.3s ease;
  font-family: 'Inter', sans-serif;
  }
  .skill-card:hover {
    background-color: #ffffff;
    transform: translateY(-5px);
  }
  .skill-card:hover .skill-info {
    max-height: 60px;
    opacity: 1;
    margin-top: 10px;
  }
  .skill-name {
    transition: color 0.3s;
  }
  .skill-card:hover .skill-name {
    color: #d12297; 
  }
  
  @keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
  }
	.skill-card:hover{
		background-color: #ffffff;
    i{
    transform: scale(1.1);
    opacity: 1;
    }
    img{
      opacity: 1;
    }
	}
  .skill-card img {
    width: 40px;
    margin-bottom: 10px;
    opacity: 0.7;
  }

  .skill-detail-box{
    font-size: clamp(0.5rem, 5vw, 1.2rem);
    font-family: cursive; 
    color: #ffffff;
    line-height: 1.5;
    margin: 10 auto;
  }

@media (max-width: 768px) {
  .skills-tabs {
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
  }
  .tab-btn {
    width: 100%;
    font-size: 0.8rem;
    padding: 10px;
  }
  .bg-title  {
    font-size: 3em;
  }
  .about-grid { 
    text-align: center;
  }
  .about-info{
    font-size: 70%;
  }
  .about-image img{
    width: 70%;
  }
  .tab-btn.active { 
    transform: translateY(0px);
  }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    renderSkills('technical');
});
  const skillsData = {
  technical: [
    { name: "Unity", icon: "devicon-unity-plain colored", info: "(Intermediate-Advanced)",detail: "ประสบการณ์ 4 ปีในการพัฒนาเกม 3D ทั้งระบบฟิสิกส์ และการทำ Optimization" },
    { name: "Blender", icon: "devicon-blender-original colored", info: "(Intermediate-Advanced)"},
    { name: "Unreal Engine ", icon: "devicon-unrealengine-original", info: "(Intermediate)" },
    { name: "C# ", icon: "devicon-csharp-line-wordmark colored" , info: "(Intermediate)"},
    { name: "HTML5/CSS ", icon: "devicon-html5-plain-wordmark colored", info: "(Intermediate)" },
    { name: "GitHub ", icon: "devicon-github-original", info: "(Intermediate)" },
    { name: "GitLab ", icon: "devicon-gitlab-plain colored" , info: "(Intermediate)"}, 
    { name: "Maya ", icon: "devicon-maya-plain colored" , info: "(Intermediate)"},
    { name: "Figma ", icon: "devicon-figma-plain colored" , info: "(Intermediate)"}
  ],
  professional: [
    { name: "Project Management", icon: "devicon-trello-plain colored" ,detail: "เคยผ่านการทำงานเป็นทีมด้วยระบบ Scrum และใช้ Trello ในการคุมงาน"},
    { name: "Game Design", icon: "devicon-figma-plain colored" },
    { name: "Problem Solving", icon: "devicon-atom-plain" }, 
    { name: "Team Collaboration", icon: "devicon-github-original" },
    { name: "Debugging", icon: "devicon-vscode-plain colored" },
    { name: "Fast Learner", icon: "devicon-google-plain colored" },
  ],
  additional: [
    { name: "Video Editing", icon: "devicon-premierepro-plain colored" ,detail: "ตัดต่อ Content ลง YouTube ช่องตัวเอง (Horror/Mystery) มีทักษะการเล่าเรื่องผ่านภาพ"},
    { name: "Photography", icon: "devicon-photoshop-plain colored" },
    { name: "Stock Trading", icon: "devicon-linux-plain" },
  ]
};

const skillTabs = document.querySelectorAll('.tab-item'); 
const gridContainer = document.getElementById('skills-grid-container');
const detailText = document.getElementById('skill-detail-text');
const defaultMessage = "ประสบการณ์...";

function renderSkills(category) {
    const skills = skillsData[category] || [];
    gridContainer.innerHTML = skills.map((skill, index) => {
      let iconContent = skill.icon 
        ? `<i class="${skill.icon}"></i>` 
        : `<img src="${skill.img}" alt="${skill.name}">`;

      return `
        <div class="skill-card" data-index="${index}" data-category="${category}">
          ${iconContent}
          <span class="skill-name">${skill.name}</span>
          <p class="skill-info">${skill.info || ''}</p>
        </div>
      `;
    }).join('');

    const cards = gridContainer.querySelectorAll('.skill-card');
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const cat = card.getAttribute('data-category');
        const idx = card.getAttribute('data-index');
        detailText.innerText = skillsData[cat][idx].detail || "ไม่มีข้อมูลเพิ่มเติม";
        detailText.style.opacity = "1";
      });

      card.addEventListener('mouseleave', () => {
        detailText.innerText = defaultMessage;
        detailText.style.opacity = "0.7";
      });
    });
}

renderSkills('technical');

skillTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      skillTabs.forEach(t => { t.classList.remove('active'); t.classList.add('inactive'); });
      tab.classList.add('active');
      tab.classList.remove('inactive');
      renderSkills(tab.getAttribute('data-category'));
    });
  });
</script>