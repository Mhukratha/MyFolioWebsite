---
import Layout from "../layouts/Layout.astro"
const projects = [
  {
    title: "I Must Survive",
    subtitle: "3D Third-Person Zombie Stealth",
    image: "/MyFolioWebpage/img/IMS.png",
    link: "https://thamanee.itch.io/ims",
    story: "In a world where human civilization has collapsed due to a zombie outbreak, a 19-year-old girl who grew up in a small shelter headed by her uncle. One day, her shelter was robbed and killed by people from other groups to steal supplies. She was the only survivor and found clues of a government shelter behind the walls, a shelter where survivors still lived as before the zombie outbreak.",
    tasks: [
      "Planned the entire development roadmap, focusing on core gameplay and story progression first.",
      "Organized and tracked every task—from coding the character system to creating cutscenes—to meet deadlines.",
      "Create the game system that is related to the player, the character code, the basic system, and the object interaction system.",
      "Make animations, cutscenes, and various objects to create scenes in the game."
    ]
  },
  {
    title: "Aenalia",
    subtitle: "The Foundation Desktop Application For EN-Card (NFT)",
    image: "/MyFolioWebpage/img/Anelia.png",
    link: "https://x.com/aenalia_space?s=20",
    story: "Aenalia is the limitless and infinite universe formed by a network of unique interconnected virtual worlds known as the Metaverse Spaces. This universe contributes by Creators/Artists through Unreal Engine, a tool that loves by creators around the world.",
    tasks: [
      "Make a map of this project with the environment inside, including animation within the work.",
      "Create 3D model works for the work of an artist and arrange the composition in the scene for beauty and realism.",
    ]
  },
  {
    title: "Verse of Cursed",
    subtitle: "BU GAME ON! final pitching round",
    image: "/MyFolioWebpage/img/Verse.png", 
    link: "https://ใส่ลิงก์ของคุณที่นี่.com/verse",
    story: "In this game, players can transform into various toys to explore a vast and exciting world of living toys. Players can use the unique abilities of each toy to overcome various obstacles on their adventure.",
    tasks: [
      "Create 3D model assets for the scence.",
      "Design and create 3D Model character in game.",
    ]
  }
];
---

<Layout title="My Work">
  <main class="relative pt-24 pb-16 md:pt-32 md:pb-20">
    <section class="container mx-auto px-6 max-w-5xl">
      
      <h2 class="text-center text-[clamp(1.5rem,5vw,2.5rem)] font-extrabold uppercase tracking-widest text-[#3b3b3b] mb-12">
        My<span class="text-[#d4af37]"> Work</span>
      </h2>

      <div class="flex flex-col items-center gap-16 md:gap-24 mt-8">
        {projects.map((project) => (
          <div class="w-full group animate-fadeIn">
            
            <div class="rounded-2xl overflow-hidden shadow-xl md:shadow-2xl transition-transform duration-500 group-hover:-translate-y-1.5 border border-white/5 bg-[#0a0a0a]">
              
              <a 
                href={project.link} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="relative aspect-video overflow-hidden block cursor-pointer"
              >
                <img 
                  src={project.image} 
                  alt={project.title} 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-85 group-hover:opacity-100"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
              </a>

              <div class="bg-[#111111] p-4 md:p-6 border-t border-white/5">
                <h3 class="nav-text text-xl md:text-2xl lg:text-3xl font-bold uppercase tracking-tight m-0">
                  {project.title}
                </h3>
                <p class="text-[#b084ff] text-[10px] md:text-xs lg:text-sm mt-2 font-serif italic opacity-80 uppercase tracking-widest">
                  {project.subtitle}
                </p>
              </div>
            </div>

            <div class="px-4 md:px-6 py-6 md:py-8 grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-10">
              
              <div class="md:col-span-5">
                <p class="text-gray-300 leading-relaxed text-sm md:text-base font-light opacity-80">
                  {project.story}
                </p>
              </div>

              <div class="md:col-span-5">
                <strong class="block text-white text-lg md:text-xl font-serif italic mb-4 border-b border-white/5 pb-2 opacity-90">
                  My Responsibilities
                </strong>
                <ul class="space-y-3 p-0 m-0 list-none">
                  {project.tasks.map((task) => (
                    <li class="relative pl-5 text-gray-400 text-xs md:text-sm lg:text-base leading-relaxed group-hover:text-gray-200 transition-colors font-light">
                      <span class="absolute left-0 text-[#d12297] font-bold opacity-80">•</span>
                      {task}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .nav-text {
    background: linear-gradient(to bottom, #FFF491 0%, #FF99CC 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.8s ease-out forwards;
  }
</style>