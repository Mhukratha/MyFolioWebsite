---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home | Yossawin">
  <main class="flex min-h-screen items-center justify-center relative overflow-hidden">

    <div class="container mx-auto px-6 md:px-20">
      <div class="max-w-5xl">
        
        <h1 class="m-0 text-[clamp(0.5rem,6vw,2.5rem)] font-black uppercase leading-[0.8] tracking-tighter text-white">
          Developer <span class="text-[#d12297]">Portfolio</span>
        </h1>

        <p class="mt-4 text-[clamp(0.8rem,3vw,1.4rem)] font-serif italic text-[#b084ff] opacity-90">
          building things for the web
        </p>

        <div class="mt-8 max-w-3xl">
          <p class="text-[clamp(0.8rem,2vw,1.25rem)] leading-relaxed text-gray-300 font-light">
            Junior Developer with a background in 
            <span class="font-bold text-white">game development</span> and growing experience in 
            <span class="font-bold text-white">front-end web development</span>. 
            Passionate about building clean, responsive interfaces using 
            <span class="font-bold text-white">HTML, CSS, Tailwind, and Astro</span>. 
            Eager to bring strong programming fundamentals and creative problem-solving 
            into a web-focused team.
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <span class="px-3 py-1 rounded-full border border-[#b084ff]/40 text-[#b084ff] text-sm">HTML & CSS</span>
          <span class="px-3 py-1 rounded-full border border-[#b084ff]/40 text-[#b084ff] text-sm">Tailwind CSS</span>
          <span class="px-3 py-1 rounded-full border border-[#b084ff]/40 text-[#b084ff] text-sm">Astro</span>
          <span class="px-3 py-1 rounded-full border border-[#b084ff]/40 text-[#b084ff] text-sm">JavaScript</span>
          <span class="px-3 py-1 rounded-full border border-[#b084ff]/40 text-[#b084ff] text-sm">Git & GitHub</span>
        </div>

      </div>
    </div>
  </main>
</Layout>