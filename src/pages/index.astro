---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home | Yossawin">
  <main class="flex min-h-screen items-center justify-center relative overflow-hidden">

    <div class="container mx-auto px-6 md:px-20">
      <div class="max-w-5xl">
        
        <h1 class="m-0 text-[clamp(0.5rem,6vw,2.5rem)] font-black uppercase leading-[0.8] tracking-tighter text-white">
          Developer <span class="text-[#d12297]">Portfolio</span>
        </h1>

        <p class="mt-4 text-[clamp(0.8rem,3vw,1.4rem)] font-serif italic text-[#b084ff] opacity-90">
          welcome to my page
        </p>

        <div class="mt-8 max-w-3xl">
          <p class="text-[clamp(0.8rem,2vw,1.25rem)] leading-relaxed text-gray-300 font-light">
            Motivated Junior Software Developer with hands-on experience in 
            <span class="font-bold text-white">C# and Unity</span>, strong in programming logic, 
            debugging, and system implementation. Eager to learn, adaptable, and seeking 
            an entry-level position to contribute to software development projects 
            in a team-based environment.
          </p>
        </div>

      </div>
    </div>
  </main>
</Layout>

