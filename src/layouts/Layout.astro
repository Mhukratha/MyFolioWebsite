---
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Yossawin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
  </head>

  <body class="bg-[#121212] text-white font-['Inter',sans-serif] m-0 p-0 overflow-x-hidden">
    <div class="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_top_right,_#3d3d3d_0%,_#000000_70%)]"></div>

    <nav class="fixed top-4 md:top-10 left-1/2 -translate-x-1/2 z-50 w-[98%] md:w-max flex justify-center">
  <div class="flex items-center gap-0.5 bg-black/90 backdrop-blur-md border border-white/10 p-0.5 md:p-2 rounded-full shadow-2xl">
    
    <a href="/MyFolioWebpage/" 
      class="px-2.5 py-2 md:px-8 md:py-3 rounded-full transition-all duration-300 hover:bg-[#333333] no-underline group whitespace-nowrap">
      <span class="nav-text font-bold uppercase tracking-tighter text-[9px] min-[375px]:text-[11px] md:text-[15px]">Home</span>
    </a>
    <a href="/MyFolioWebpage/about" 
      class="px-2.5 py-2 md:px-8 md:py-3 rounded-full transition-all duration-300 hover:bg-[#333333] no-underline group whitespace-nowrap">
      <span class="nav-text font-bold uppercase tracking-tighter text-[9px] min-[375px]:text-[11px] md:text-[15px]">About me</span>
    </a>
    <a href="/MyFolioWebpage/work" 
      class="px-2.5 py-2 md:px-8 md:py-3 rounded-full transition-all duration-300 hover:bg-[#333333] no-underline group whitespace-nowrap">
      <span class="nav-text font-bold uppercase tracking-tighter text-[9px] min-[375px]:text-[11px] md:text-[15px]">My work</span>
    </a>
    <a href="/MyFolioWebpage/contact" 
      class="px-2.5 py-2 md:px-8 md:py-3 rounded-full transition-all duration-300 hover:bg-[#333333] no-underline group whitespace-nowrap">
      <span class="nav-text font-bold uppercase tracking-tighter text-[9px] min-[375px]:text-[11px] md:text-[15px]">Contact</span>
    </a>
  </div>
</nav>

    <slot />

    <style is:global>
      .nav-text {
        background: linear-gradient(to bottom, #fff491 0%, #ff99cc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: inline-block;
      }
    </style>
  </body>
</html>
